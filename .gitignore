# macOS cruft
.DS_Store

# Editor / IDE local files
.vscode/
.idea/
*.swp
# Node, if anything in the toolchain ends up using it
node_modules/
# Local environment files — never commit these
.env
.env.*
local-keys.txt
*.local.*
# Build outputs (we publish the zip via GitHub Releases, not git)
dist/*.zip
!dist/.gitkeep
# esbuild bundle output — regenerated from chrome-extension/ source
build/
# package-lock from npm install (we don't commit lockfiles for the
# minimal dev-only toolchain — esbuild is the only direct dep)
package-lock.json
# Backup files
*.bak
*~
*-next-session-brief.md
next-session-brief.md
