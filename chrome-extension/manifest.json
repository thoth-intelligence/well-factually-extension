{
  "manifest_version": 3,
  "name": "Live Fact-Check Sidebar",
  "version": "0.6.0",
  "description": "Streams live fact-flags alongside YouTube videos via Vertex AI (Gemini Flash primary, optional Llama/Grok/Claude consensus) with optional Google AI Studio fallback for the citation + dossier paths. Local LM Studio backend also supported.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://aiplatform.googleapis.com/*",
    "https://*.aiplatform.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Live Fact-Check Sidebar"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
